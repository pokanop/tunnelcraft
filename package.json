{
  "name": "tunnelcraft",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:server": "bun run --cwd server dev",
    "dev:client": "bun run --cwd client dev",
    "build": "bun run --cwd client build",
    "start": "bun run --cwd server start",
    "test": "bun test",
    "preview": "bun run --cwd client preview",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsc -p client && tsc -p server",
    "check": "bun run lint && bun run format:check && bun run typecheck",
    "setup:hooks": "git config core.hooksPath .githooks",
    "clean": "rm -rf node_modules client/node_modules server/node_modules client/dist"
  },
  "devDependencies": {
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
