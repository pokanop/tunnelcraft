# Copy this file to server/.env and fill in what you need.
# Every variable here has a working default except the OAuth secrets —
# the app runs with zero configuration for local dev (email links just log to stdout).

# --- Core ---
PORT=4000
NODE_ENV=development
DATA_DIR=./data
LOG_LEVEL=info
SHUTDOWN_TIMEOUT_MS=10000

# --- Social login (Arctic: Google + GitHub) ---
# Leave unset to disable a provider — /api/auth/providers reports only configured ones.
BASE_URL=http://localhost:4000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Mail ---
# Unset: verification/reset links log to the server console (fine for local dev).
# Set to wire a real SMTP transport in server/src/mail.js.
SMTP_HOST=

# --- Backups ---
# Unset disables POST /api/admin/backup entirely.
BACKUP_TOKEN=
